# Kopiere diese Datei nach secrets.yaml (nicht ins Git-Repo committen!)
# und trage die echten Werte ein.

wifi_ssid: "DEIN_WLAN_NAME"
wifi_password: "DEIN_WLAN_PASSWORT"

# Fallback-Access-Point, falls das Gerät sich nicht mit dem WLAN verbinden kann
wifi_ap_password: "EinSicheresFallbackPasswort123"

# API-Verschlüsselungsschlüssel (Base64, 32 Byte).
# Erzeugen z.B. mit: openssl rand -base64 32
api_key: "HIER_BASE64_KEY_EINFUEGEN"

# OTA-Update-Passwort
ota_password: "EinSicheresOtaPasswort123"
